PLATFORM_DB_NAME=querycraft
PLATFORM_DB_USER=querycraft
PLATFORM_DB_PASSWORD=querycraft_dev
PLATFORM_DB_PORT=5433

# ─── Source Database ───
SOURCE_DB_NAME=source_analytics
SOURCE_DB_HOST=localhost
SOURCE_DB_PORT=5434
SOURCE_DB_USER=source_readonly
SOURCE_DB_PASSWORD=source_dev
SOURCE_DB_SSL_MODE=disable

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ─── Security ───
PLATFORM_ENCRYPTION_KEY=dGVzdC1lbmNyeXB0aW9uLWtleS0zMi1ieXRlcw==
ALLOWED_ORIGINS=http://localhost:3000

# ─── Admin User ───
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=Administrator
