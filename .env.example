# ─── QueryCraft Environment Configuration ───
# Copy this file to .env and fill in the required values:
#   cp .env.example .env

# ─── Platform Database (used by backend for app state) ───
# Required — no default. Full asyncpg connection string.
DATABASE_URL=postgresql+asyncpg://querycraft:querycraft_dev@postgres-platform:5432/querycraft
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Compose-only vars (used by docker-compose.dev.yml to create the container):
PLATFORM_DB_NAME=querycraft
PLATFORM_DB_USER=querycraft
PLATFORM_DB_PASSWORD=querycraft_dev

# ─── Source Database (read-only role for query execution) ───
SOURCE_DB_HOST=postgres-source
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=source_analytics
SOURCE_DB_USER=source_readonly
SOURCE_DB_PASSWORD=source_dev
SOURCE_DB_SSL_MODE=disable

# Pagila read-only role (used by SourceDBConnector — see Chunk 3.4)
PAGILA_READONLY_USER=pagila_user
PAGILA_READONLY_PASSWORD=pagila_dev_pwd

# ─── Redis (sessions, locks, ephemeral attempts) ───
REDIS_URL=redis://redis:6379/0

# ─── Security ───
# Required — 32-byte base64-encoded key for AES-256-GCM encryption.
# Generate with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
PLATFORM_ENCRYPTION_KEY=

# Origins allowed by the CORS / session middleware (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# ─── Admin User (read by Alembic migration 002_seed_admin_user) ───
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=Platform Administrator
ADMIN_PASSWORD=changeme-please

# ─── LLM Provider (anthropic | openai | gemini | ollama) ───
LLM_PROVIDER=anthropic
LLM_API_KEY_ANTHROPIC=
LLM_API_KEY_OPENAI=
LLM_API_KEY_GEMINI=
LLM_BASE_URL_OLLAMA=http://localhost:11434

# ─── Application Tunables (override defaults if needed) ───
QUERY_TIMEOUT_SECONDS=30
MAX_QUESTION_LENGTH=2000
SESSION_IDLE_TIMEOUT_HOURS=8
SCHEMA_CACHE_TTL_SECONDS=300
MAX_SCHEMA_TOKENS=60000

# ─── Logging ───
LOG_LEVEL=INFO

# ─── Docker Compose Ports (host-side mapping) ───
BACKEND_PORT=8000
FRONTEND_PORT=5173
